rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && getUserRole() == 'admin';
    }

    function isPolice() {
      return isSignedIn() && getUserRole() == 'police';
    }

    function isAdminOrPolice() {
      return isSignedIn() && (getUserRole() == 'admin' || getUserRole() == 'police');
    }

    // ── Users collection ─────────────────────────────────
    match /users/{userId} {
      allow read:  if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    // ── Regular Complaints collection ────────────────────
    // Police & admin can see all complaints; users can read only their own
    match /complaints/{complaintId} {
      allow read:   if isAdminOrPolice() || isOwner(resource.data.authorId);
      allow create: if isSignedIn();
      allow update: if isAdminOrPolice();
      allow delete: if isAdmin();
    }

    // ── Challan Complaints collection ────────────────────
    // Users: read/create their own
    // Police & Admin: read all + update (status, adminResponse)
    match /challanComplaints/{complaintId} {
      allow read:   if isAdminOrPolice() || isOwner(resource.data.authorId);
      allow create: if isSignedIn();
      allow update: if isAdminOrPolice();
      allow delete: if isAdmin();  // Only admins can delete
    }

    // ── Police Activity Log ───────────────────────────────
    // Only police & admin can read/write
    match /policeActivityLog/{logId} {
      allow read:  if isAdminOrPolice();
      allow write: if isAdminOrPolice();
    }

    // ── Admin Activity Log ────────────────────────────────
    match /activityLog/{logId} {
      allow read:  if isAdmin();
      allow write: if isAdmin();
    }

    // ── Chat History ─────────────────────────────────────
    match /chatHistory/{docId} {
      allow read:  if isOwner(resource.data.userId) || isAdmin();
      allow write: if isSignedIn();
    }
  }
}
